{
    "name": "netscaler",
    "displayName": "ns.conf",
    "description": "Syntax highlighting and snippets for Citrix ADC/NetScaler configuration (ns.conf) files.",
    "version": "1.1.0",
    "publisher": "timdenholm",
    "license": "APACHE",
    "icon": "images/icon.png",
    "engines": {
        "vscode": "^1.63.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/timdenholm/vscode-netscaler/"
    },
    "bugs": {
        "url": "https://github.com/timdenholm/vscode-netscaler/issues/"
    },
    "categories": [
        "Programming Languages",
        "Snippets"
    ],
    "scripts": {
        "test": "vscode-tmgrammar-test -g syntaxes/netscaler.tmLanguage.json \"tests/*.test.txt\""
    },
    "devDependencies": {
        "vscode-tmgrammar-test": "^0.1.3"
    },
    "contributes": {
        "languages": [
            {
                "id": "netscaler",
                "aliases": [
                    "NetScaler",
                    "netscaler"
                ],
                "extensions": [
                    ".conf"
                ],
                "filenames": [
                    "ns.conf"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "netscaler",
                "scopeName": "text.netscaler",
                "path": "./syntaxes/netscaler.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "netscaler",
                "path": "./snippets/base-config.json"
            },
            {
                "language": "netscaler",
                "path": "./snippets/basic.json"
            },
            {
                "language": "netscaler",
                "path": "./snippets/content-switching.json"
            },
            {
                "language": "netscaler",
                "path": "./snippets/load-balancing.json"
            },
            {
                "language": "netscaler",
                "path": "./snippets/networking.json"
            },
            {
                "language": "netscaler",
                "path": "./snippets/ns.json"
            },
            {
                "language": "netscaler",
                "path": "./snippets/ssl.json"
            }
        ]
    }
}