            "match": "(?<=(?i:vserver|service|servicegroup).*\\s)(ADNS|ADNS_DOT|ADNS_TCP|ANY|DHCPRA|DIAMETER|DNS|DNS_TCP|DOT|DTLS|FIX|FTP|GRE|HDX|HTTP|HTTP_QUIC|IPFIX|LOGSTREAM|LOGSTREAM_SSL|MONGO|MONGO_TLS|MQTT|MQTT_TLS|MSSQL|MYSQL|NNTP|ORACLE|PPTP|PROXY|PUSH|QUIC|QUIC_BRIDGE|RADIUS|RADIUSListener|RDP|RPCSVR|RTSP|SIP_SSL|SIP_TCP|SIP_UDP|SMPP|SNMP|SSL|SSL_BRIDGE|SSL_DIAMETER|SSL_FIX|SSL_PROXY|SSL_PUSH|SSL_TCP|SYSLOGTCP|SYSLOGUDP|TCP|TFTP|UDP|USER_SSL_TCP|USER_TCP)(?=\\s|$)",
            "name": "entity.name.function.netscaler"
